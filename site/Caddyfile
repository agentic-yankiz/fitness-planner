# Local Caddy server for the fitness site.
#
# The launchd service builds ./dist with BASE_PATH=/fitness and runs the Node
# server (server.mjs) on 127.0.0.1:3000. Tailscale Serve exposes this path by
# proxying /fitness directly to the Node server root:
#   https://shakeds-macbook-pro-2.tail0b783.ts.net/fitness/
#
# This Caddy route is kept for local browser access at:
#   http://localhost:8080/fitness/
#
# Loopback-only bind: this local convenience proxy must not be reachable from
# the LAN. Do not widen this bind — the write-auth trust model in
# docs/infra/tailscale-serving.md depends on loopback-only backends.
#
# reverse_proxy forwards ALL request headers unchanged. handle_path strips the
# /fitness prefix, so Node sees /, /styles.css, /api/done, etc.

# The explicit http:// scheme matters: a bare host+port address ("127.0.0.1:8080")
# qualifies for Caddy's automatic HTTPS. http:// keeps this local route on a
# loopback-only plain-HTTP bind.
http://127.0.0.1:{$FITNESS_SITE_PORT:8080} {
	handle /fitness {
		redir * /fitness/ 301
	}

	handle_path /fitness/* {
		reverse_proxy 127.0.0.1:{$FITNESS_SERVER_PORT:3000}
	}

	handle {
		redir * /fitness/ 302
	}

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}
}
