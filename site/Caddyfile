# Local Caddy server for the fitness site.
#
# The launchd service builds ./dist with BASE_PATH=/fitness, serves it on
# localhost:8080, and asks Tailscale Serve to expose this path at:
#   https://shakeds-macbook-pro-2.tail0b783.ts.net/fitness/

:{$FITNESS_SITE_PORT:8080} {
	handle /fitness {
		redir * /fitness/ 301
	}

	handle_path /fitness/* {
		root * {$SITE_DIST}
		encode gzip
		file_server
	}

	handle {
		redir * /fitness/ 302
	}

	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy no-referrer
	}
}
