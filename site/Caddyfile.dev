# Local development Caddyfile for the fitness site.
# Serves the static site at /fitness path prefix with no auth.
#
# Run with:
#   SITE_DIST=$(pwd)/dist caddy run --config Caddyfile.dev --adapter caddyfile
#
# Then access at: http://localhost:8080/fitness

:8080 {
	# Redirect /fitness (no trailing slash) → /fitness/
	handle /fitness {
		redir /fitness/ 301
	}

	handle_path /fitness/* {
		root * {$SITE_DIST}
		file_server
		encode gzip
	}
}
